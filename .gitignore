# =========================================
# 1. Bỏ qua các file và folder Build/Biên dịch
# =========================================
[Bb]in/
[Oo]bj/
**/bin/
**/obj/

# =========================================
# 2. Bỏ qua các file cấu hình nhạy cảm
# =========================================
# (GIỮ LẠI appsettings.json để làm template cho team)
# Bỏ qua mọi file appsettings theo môi trường
**/appsettings.Development.json
**/appsettings.Production.json
**/appsettings.Secret.json
**/appsettings.*.json
secrets.json
# File .env chứa secret production cho docker-compose.prod.yml
.env
# Firebase Admin SDK credentials (Notification service)
**/firebase-credentials.json
**/*firebase-adminsdk*.json
**/fcm-service-account.json
# Thư mục chứa secret mount vào container (FCM key, ...)
secrets/
**/secrets/

# =========================================
# 3. Bỏ qua thư mục sinh ra khi chạy App (Log/Data)
# =========================================
**/logs/
*.log
*.sqlite
*.db
# LƯU Ý: Đã comment dòng dưới để không bị đá với phần 2 (giữ lại template)
appsettings.json

# =========================================
# 4. Môi trường IDE và Hệ điều hành (Visual Studio, VS Code, Rider, Mac)
# =========================================
.vs/
*.user
.vscode/
.idea/
.DS_Store

# =========================================
# 5. Cấu hình Terraform (Tránh push file nặng và state)
# =========================================
# Bỏ qua thư mục chứa provider plugin tải về (nặng hàng trăm MB)
**/.terraform/
# Bỏ qua file state chứa thông tin cấu hình và dữ liệu thật
*.tfstate
*.tfstate.backup
# Bỏ qua file lock version của provider
.terraform.lock.hcl
*.tfvars