# ─────────────────────────────────────────────────────────────────────────────
# Biến môi trường cho PRODUCTION (docker-compose.prod.yml)
#
# Cách dùng:
#   1. Copy file này thành .env:   cp .env.example .env
#   2. Điền giá trị thật vào (lấy từ appsettings.json đang có sẵn)
#   3. Chạy:
#      docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env up -d
#
# LƯU Ý: .env chứa secret thật -> KHÔNG commit lên git (thêm vào .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker image (GHCR) ──────────────────────────────────────────────────────
# IMAGE_OWNER = tên owner repo GitHub (viết thường), IMAGE_TAG mặc định "latest"
IMAGE_OWNER=your_github_username_lowercase
IMAGE_TAG=latest

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (Identity / User / Friend / Post) — lấy từ appsettings.json
DB_CONNECTION=Host=...; Database=...; Username=...; Password=...; SSL Mode=VerifyFull; Channel Binding=Require;
# MongoDB Atlas (Message service)
MONGODB_CONNECTION=mongodb+srv://user:password@cluster.mongodb.net/?appName=Message

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET phải GIỐNG NHAU ở tất cả service (Identity ký, các service khác verify)
JWT_SECRET=your_jwt_secret_32_chars_min
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── External services ────────────────────────────────────────────────────────
# Brevo (gửi email xác thực - Identity service)
BREVO_API_KEY=xkeysib-...
# URL public của VM/domain để chèn vào link xác thực email
APP_BASE_URL=http://YOUR_VPS_IP:5210
# Cloudinary (upload ảnh - User / Post service)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Agora (voice/video call - Message service). AppId phải GIỐNG với frontend (--dart-define=AGORA_APP_ID)
AGORA_APP_ID=256733ae43b748bc8262e674ef5fc862
AGORA_APP_CERTIFICATE=721913c8bd1e45afb4490aad4e44ca86
